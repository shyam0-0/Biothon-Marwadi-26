<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme applied before Compose takes over. Keeps the splash/window
         background aligned with the app's medical-blue palette to avoid flashes. -->
    <style name="Theme.MedFusion" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/md_surface</item>
        <item name="android:navigationBarColor">@color/md_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/md_surface</item>
    </style>
</resources>
